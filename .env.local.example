# Nutribar — variáveis de ambiente
#
# Copie este ficheiro para `.env.local` e preencha com os valores reais:
#
#   cp .env.local.example .env.local
#
# `.env.local` está ignorado pelo git — nunca faça commit de chaves reais.


# ─────────────────────────────────────────────────────────────────────────────
# OBRIGATÓRIAS — sem estas a aplicação não arranca
# ─────────────────────────────────────────────────────────────────────────────

# Supabase → Dashboard → Settings → API
#
# SUPABASE_URL          : campo "Project URL"
# SUPABASE_ANON_KEY     : chave `anon` / `public`
# SUPABASE_SERVICE_ROLE_KEY : chave `service_role` (carregue em "Reveal")
#
# ATENÇÃO: a service_role ignora as políticas RLS e dá acesso total à base de
# dados. Só no servidor, só neste ficheiro. Se vazar, revogue-a no painel.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Mesmos valores que SUPABASE_URL e SUPABASE_ANON_KEY acima, repetidos com o
# prefixo NEXT_PUBLIC_ para o browser lhes aceder. O chat em tempo real usa-os
# para escutar o canal do Supabase (src/components/chat-room.tsx).
#
# Só a chave anon (pública) é exposta ao browser — a service_role nunca.
# Sem estas duas o chat continua a enviar mensagens, mas deixa de as receber
# em tempo real: é preciso recarregar a página para ver as novas.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

# Segredo que assina os cookies de sessão (JWT HS256, src/lib/session-token.ts).
# Gere uma string longa e aleatória — em produção nunca reutilize a de dev:
#
#   openssl rand -base64 32
#
# Ao alterá-lo, todas as sessões activas são invalidadas e os utilizadores
# têm de entrar novamente.
SESSION_SECRET=local-dev-secret-change-in-production


# ─────────────────────────────────────────────────────────────────────────────
# OPCIONAIS — a aplicação arranca sem elas, com funcionalidades reduzidas
# ─────────────────────────────────────────────────────────────────────────────

# E-mails separados por vírgula que se tornam admin ao registar-se
# (src/app/actions/auth.ts). Vazio = nenhuma conta nova vira admin.
ADMIN_EMAILS=seu@email.com

# Resend — notificações por e-mail do chat (src/lib/email.ts).
# Faltando qualquer uma das duas, o envio torna-se um no-op silencioso: o chat
# funciona na mesma, apenas não avisa por e-mail. Confortável em dev.
#
# RESEND_API_KEY  : resend.com → API Keys
# CHAT_EMAIL_FROM : remetente com domínio verificado no Resend
RESEND_API_KEY=
CHAT_EMAIL_FROM=Nutribar <no-reply@example.com>

# URL público, usado nos links de indicação e de acesso das nutricionistas.
# Deixe VAZIO: por omissão deriva do host da requisição, o que funciona tanto
# em localhost como no domínio publicado (src/lib/base-url.ts).
#
# Defina apenas para forçar um domínio fixo. Um valor errado aqui gera links
# quebrados para quem os receber — foi por isso que passou a ser derivado.
NEXT_PUBLIC_APP_URL=
