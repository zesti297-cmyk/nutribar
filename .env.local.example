# Database
DATABASE_URL=postgres://nutribar:nutribar@localhost:5432/nutribar
# If you want to use Supabase Postgres, replace DATABASE_URL with the Supabase connection string.

# Session signing (use a long random string in production)
SESSION_SECRET=local-dev-secret-change-in-production

# App URL (used for affiliate links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated emails that become admin on signup
ADMIN_EMAILS=seu@email.com
